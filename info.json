{
  "identifier": "bob-plugin-openrouter-tts",
  "version": "1.1.0",
  "category": "tts",
  "name": "OpenRouter TTS",
  "summary": "使用 OpenRouter TTS API 进行语音合成，覆盖全部 speech-output 模型。",
  "icon": "",
  "author": "poyih & Claude",
  "homepage": "https://github.com/poyih/bob-plugin-openrouter-tts",
