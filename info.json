  "minBobVersion": "1.8.0",
  "options": [
    {
      "identifier": "apiKey",
      "type": "text",
      "title": "API Key",
      "defaultValue": "",
      "textConfig": {
        "type": "secure",
        "placeholderText": "sk-or-v1-..."
      }
    },
    {
      "identifier": "apiUrl",
      "type": "text",
      "title": "API URL",
      "defaultValue": "https://openrouter.ai/api/v1/audio/speech",
      "desc": "OpenRouter TTS 接口地址。支持填写 https://openrouter.ai、https://openrouter.ai/api、https://openrouter.ai/api/v1、完整 /audio/speech 地址，或 legacy/custom /tts 地址。",
      "textConfig": {
        "type": "visible",
        "placeholderText": "https://openrouter.ai/api/v1/audio/speech"
      }
    },
